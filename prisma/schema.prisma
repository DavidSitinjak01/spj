// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Toko {
  id        String   @id @default(cuid())
  namaToko  String
  direktur  String   @default("")
  noHp      String   @default("")
  alamat    String   @default("")
  kategori  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bpus BPU[]
  bnus BNU[]
}

model DataSekolah {
  id              String   @id @default(cuid())
  namaSekolah     String   @default("")
  npsn            String   @default("")
  alamat          String   @default("")
  kabupaten       String   @default("")
  provinsi        String   @default("")
  kepalaSekolah   String   @default("")
  nipKepala       String   @default("")
  bendahara       String   @default("")
  nipBendahara    String   @default("")
  pengurusBarang  String   @default("")
  nipPengurus     String   @default("")
  penerimaBarang  String   @default("")
  nipPenerima     String   @default("")
  logoKiriUrl     String   @default("")  // base64 data URL of left logo (e.g., Garuda/national emblem)
  logoKananUrl    String   @default("")  // base64 data URL of right logo (e.g., school logo)
  logoKiriLebar   Float    @default(2.5) // width in cm
  logoKiriTinggi  Float    @default(3.0) // height in cm
  logoKananLebar  Float    @default(2.5) // width in cm
  logoKananTinggi Float    @default(3.0) // height in cm
  garisBawahStyle String   @default("single-thick") // line style: 'single-thin', 'single-thick', 'double', 'double-thick-thin', 'none'
  garisBawahJarak Float    @default(4)   // spacing between last KOP row and line (in pt)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kopRows KopRow[]
}

model KopRow {
  id            String   @id @default(cuid())
  dataSekolahId String
  dataSekolah   DataSekolah @relation(fields: [dataSekolahId], references: [id], onDelete: Cascade)
  urutan        Int      @default(0)     // order/position (1 = first row)
  teks          String   @default("")    // text content (e.g., "PEMERINTAH KABUPATEN TANGERANG")
  fontFamily    String   @default("Times New Roman")  // font family
  fontSize      Float    @default(12)    // font size in pt
  lineHeight    Float    @default(1.3)   // line height multiplier (e.g., 1.0 = tight, 1.5 = normal, 2.0 = loose)
  bold          Boolean  @default(false) // bold text
  italic        Boolean  @default(false) // italic text
  uppercase     Boolean  @default(false) // transform to uppercase
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BPU {
  id               String   @id @default(cuid())
  noBukti          String   @unique  // e.g., "BPU01", "BPU02"
  noPesanan        String   @default("")  // 3-digit manual input, e.g., "001"
  tglPesan         String   @default("")  // ISO date string
  tokoId           String?  
  toko             Toko?    @relation(fields: [tokoId], references: [id], onDelete: SetNull)
  bkuFileName      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Auto-generated nomor surat (computed from formula)
  // Pesanan: "421.3/" + NoPesanan + "-P/DB/SMANSATLD/" + RomanMonth(TglPesan) + "/" + Year(TglPesan)
  // BAST:    "421.3/" + NoPesanan + "-BAST/SMANSA-TD/" + RomanMonth(TglPesan) + "/" + Year(TglPesan)
  // SHP:     "421.3/" + NoPesanan + "-PB/SMANSA-TD/" + RomanMonth(TglPesan) + "/" + Year(TglPesan)

  // Items with harga toko 2 for comparison
  items BPItem[]
}

model BPItem {
  id            String   @id @default(cuid())
  bpuId         String
  bpu           BPU      @relation(fields: [bpuId], references: [id], onDelete: Cascade)
  uraian        String   @default("")       // Item description from BKU
  kodeRekening  String   @default("")       // Kode Rekening
  jumlah        Float    @default(0)        // Amount from BKU
  hargaToko2    Float    @default(0)        // Comparison price (manual input)
  volume        String   @default("")       // Volume
  satuan        String   @default("")       // Satuan
  tarifHarga    Float    @default(0)        // Unit price
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BNU {
  id               String   @id @default(cuid())
  noBukti          String   @unique  // e.g., "BNU01", "BNU02"
  noPesanan        String   @default("")  // 3-digit manual input
  tglPesan         String   @default("")  // ISO date string
  tokoId           String?
  toko             Toko?    @relation(fields: [tokoId], references: [id], onDelete: SetNull)
  bkuFileName      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items BNUItem[]
}

model BNUItem {
  id            String   @id @default(cuid())
  bnuId         String
  bnu           BNU      @relation(fields: [bnuId], references: [id], onDelete: Cascade)
  uraian        String   @default("")
  kodeRekening  String   @default("")
  jumlah        Float    @default(0)
  hargaToko2    Float    @default(0)
  volume        String   @default("")
  satuan        String   @default("")
  tarifHarga    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
